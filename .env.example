# Gemini AI
EXPO_PUBLIC_GEMINI_API_KEY=

# Splitwise OAuth app credentials
# Register at: https://secure.splitwise.com/apps/new
# Set redirect URI to: budgetmybs://auth/splitwise
EXPO_PUBLIC_SPLITWISE_CLIENT_ID=
EXPO_PUBLIC_SPLITWISE_CLIENT_SECRET=

# Splitwise dev shortcut — paste your personal API key from
# https://secure.splitwise.com/account/edit (scroll to "Your apps")
# Takes priority over OAuth when set. Remove before production build.
EXPO_PUBLIC_SPLITWISE_API_KEY=
